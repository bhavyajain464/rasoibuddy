# Backend HTTP port (use 8080 for local/dev and for EXPO_PUBLIC_API_BASE_URL on the app).
PORT=8080
DATABASE_URL=
# Small pool defaults for shared / remote Postgres (raise only if you need more API concurrency).
DB_MAX_OPEN_CONNS=6
DB_MAX_IDLE_CONNS=2
DB_CONN_MAX_LIFETIME_MIN=5
DB_CONN_MAX_IDLE_SEC=90
ENVIRONMENT=
GEMINI_API_KEY=
GEMINI_MODEL=
# LLM for shelf-life, meals, bill scan: "groq" (default) or "gemini". Only one provider per request — no fallback.
LLM_PROVIDER=groq
# Required when LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=
# Small model for WhatsApp message NLU (lower token use than GROQ_MODEL)
GROQ_NLU_MODEL=
GROQ_VISION_MODEL=
GOOGLE_TRANSLATE_KEY=
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
SESSION_TOKEN_SECRET=
# Optional: Valkey/Redis for cooked-dish history cache (last 15 days). Use rediss:// for Aiven TLS.
# REDIS_URL=rediss://default:PASSWORD@your-service.aivencloud.com:PORT
REDIS_URL=
KAFKA_ENABLED=true
KAFKA_BROKERS=
KAFKA_TOPIC_SHELFLIFE=
KAFKA_SASL_ENABLED=false
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_USERNAME=
KAFKA_PASSWORD=
KAFKA_TLS_ENABLED=false
KAFKA_CA_FILE=
# Low-throughput defaults (safe for small brokers / shared VMs). Override only if needed.
KAFKA_TOPIC_PARTITIONS=1
KAFKA_WRITER_BATCH_SIZE=1
KAFKA_WRITER_BATCH_BYTES=4096
KAFKA_WRITER_BATCH_TIMEOUT_SEC=5
KAFKA_WRITER_MAX_ATTEMPTS=2
KAFKA_WRITER_ASYNC=false
KAFKA_CONSUMER_MAX_BYTES=262144
KAFKA_CONSUMER_MAX_WAIT_SEC=10
KAFKA_CONSUMER_COMMIT_INTERVAL_SEC=30
KAFKA_CONSUMER_READ_BACKOFF_MIN_MS=2000
KAFKA_CONSUMER_READ_BACKOFF_MAX_MS=8000
KAFKA_CONSUMER_HEARTBEAT_SEC=10
KAFKA_CONSUMER_SESSION_TIMEOUT_SEC=60
KAFKA_CONSUMER_JOIN_GROUP_BACKOFF_SEC=10
KAFKA_CONSUMER_ERROR_BACKOFF_SEC=10
KAFKA_CONSUMER_QUEUE_CAPACITY=1
# Smaller Gemini batches + pause between batches spreads DB writes after LLM calls.
KAFKA_CONSUMER_GEMINI_BATCH_SIZE=12
KAFKA_CONSUMER_PAUSE_BETWEEN_BATCHES_MS=150
