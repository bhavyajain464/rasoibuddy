# Backend HTTP port (use 8080 for local/dev and for EXPO_PUBLIC_API_BASE_URL on the app).
PORT=8080
DATABASE_URL=
# Small pool defaults for shared / remote Postgres (raise only if you need more API concurrency).
DB_MAX_OPEN_CONNS=6
DB_MAX_IDLE_CONNS=2
DB_CONN_MAX_LIFETIME_MIN=5
DB_CONN_MAX_IDLE_SEC=90
ENVIRONMENT=

# Admin API (X-Admin-Key header). Required for POST /api/v1/admin/*
#   /admin/subscriptions/cancel
#   /admin/meal-of-day/refresh       — repopulate cache (optional JSON: user_id, email)
#   /admin/meal-of-day/clear-cache   — delete all mealofday:* Redis keys
#   /admin/inventory/backfill-food-groups — LLM food_group for all inventory (optional JSON: user_id)
ADMIN_API_KEY=

# Complimentary premium (no Razorpay): checked on every entitlements load.
# PREMIUM_GRANT_TIER=pro   (default pro; use elite for full Elite features incl. diet email)
# Local .env: comma-separated. Cloud Run deploy: semicolon-separated (see deploy-backend.yml).
# PREMIUM_GRANT_EMAILS=you@example.com,teammate@example.com

# Razorpay premium checkout — RAZORPAY_ENV selects staging (test) vs production (live) keys.
# staging: Dashboard → Test Mode keys. production: Live Mode keys + live webhook secret.
RAZORPAY_ENV=staging
RAZORPAY_KEY_ID_STAGING=
RAZORPAY_KEY_SECRET_STAGING=
RAZORPAY_WEBHOOK_SECRET_STAGING=
RAZORPAY_KEY_ID_PRODUCTION=
RAZORPAY_KEY_SECRET_PRODUCTION=
RAZORPAY_WEBHOOK_SECRET_PRODUCTION=
# Legacy fallback currency (prices are in internal/services/plans.go: Pro ₹99/mo, ₹899/yr)
RAZORPAY_PREMIUM_AMOUNT_PAISE=9900
RAZORPAY_PREMIUM_CURRENCY=INR
GEMINI_API_KEY=
GEMINI_MODEL=
# LLM for shelf-life, meals, bill scan: "groq" (default) or "gemini". Only one provider per request — no fallback.
# PDF bill scans use Groq text extraction (Swiggy Instamart, Blinkit, etc.) when LLM_PROVIDER=groq.
# Image bill scans: GCP Cloud Vision TEXT_DETECTION (1 free unit/photo, 1000/mo free) → Groq text model.
# Setup: docs/GOOGLE_VISION_SETUP.md — use a GCP API key, not GEMINI_API_KEY from AI Studio.
LLM_PROVIDER=groq
# Required when LLM_PROVIDER=groq. Multiple keys: comma-separated; one is chosen at random per request.
GROQ_API_KEY=
# Primary Groq model for meals, bill scan, shelf-life, WhatsApp NLU, diet analysis
GROQ_MODEL=llama-3.3-70b-versatile
# Optional overrides (default: same as GROQ_MODEL)
GROQ_NLU_MODEL=llama-3.3-70b-versatile
# Required for photo bill scans when LLM_PROVIDER=groq. Enable vision.googleapis.com on kitchmate-495620.
GOOGLE_VISION_API_KEY=
GOOGLE_TRANSLATE_KEY=
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
SESSION_TOKEN_SECRET=
# Optional: SMTP for nightly diet digest emails (Elite, 1 AM IST).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@yourdomain.com

# Optional: Valkey/Redis for cooked-dish history cache (last 15 days). Use rediss:// for Aiven TLS.
# REDIS_URL=rediss://default:PASSWORD@your-service.aivencloud.com:PORT
REDIS_URL=
# Kitchen week plan cache TTL in Redis (hours). Default: 4
MEAL_PLAN_CACHE_TTL_HOURS=4

# Force-update: block native apps below these minimums (GET /api/v1/app/config + API middleware).
# Enforcement applies to ALL native API calls, including legacy app builds without version headers
# (detected via okhttp/CFNetwork user agents). Web clients must send X-App-Platform: web.
# Set MIN_*_BUILD after the new store build is live (0 = disabled until you flip it).
# Example after shipping Android build 42: MIN_ANDROID_BUILD=42
# MIN_ANDROID_VERSION=1.0.1
# MIN_ANDROID_BUILD=0
# MIN_IOS_VERSION=1.0.1
# MIN_IOS_BUILD=0
# APP_UPDATE_MESSAGE=A new version of Rasoibuddy is required. Please update from the store to continue.
# PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.kitchenai.app
# APP_STORE_URL=
KAFKA_ENABLED=true
KAFKA_BROKERS=
KAFKA_TOPIC_SHELFLIFE=
KAFKA_SASL_ENABLED=false
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_USERNAME=
KAFKA_PASSWORD=
KAFKA_TLS_ENABLED=false
KAFKA_CA_FILE=
# Low-throughput defaults (safe for small brokers / shared VMs). Override only if needed.
KAFKA_TOPIC_PARTITIONS=1
KAFKA_WRITER_BATCH_SIZE=1
KAFKA_WRITER_BATCH_BYTES=4096
KAFKA_WRITER_BATCH_TIMEOUT_SEC=5
KAFKA_WRITER_MAX_ATTEMPTS=2
KAFKA_WRITER_ASYNC=false
KAFKA_CONSUMER_MAX_BYTES=262144
KAFKA_CONSUMER_MAX_WAIT_SEC=10
KAFKA_CONSUMER_COMMIT_INTERVAL_SEC=30
KAFKA_CONSUMER_READ_BACKOFF_MIN_MS=2000
KAFKA_CONSUMER_READ_BACKOFF_MAX_MS=8000
KAFKA_CONSUMER_HEARTBEAT_SEC=10
KAFKA_CONSUMER_SESSION_TIMEOUT_SEC=60
KAFKA_CONSUMER_JOIN_GROUP_BACKOFF_SEC=10
KAFKA_CONSUMER_ERROR_BACKOFF_SEC=10
KAFKA_CONSUMER_QUEUE_CAPACITY=1
# Smaller Gemini batches + pause between batches spreads DB writes after LLM calls.
KAFKA_CONSUMER_GEMINI_BATCH_SIZE=12
KAFKA_CONSUMER_PAUSE_BETWEEN_BATCHES_MS=150

# Zomato order sync (in-process Go worker; Settings → Start Zomato sync)
ZOMATO_MAX_ORDERS_PER_SYNC=15
# Public URL for Zomato connect popup/proxy (defaults to request Host if unset)
API_PUBLIC_URL=http://localhost:8080
# Optional legacy secret for POST .../integrations/zomato/ingest
ZOMATO_WORKER_SECRET=kitchenai-zomato-dev-secret

# Commerce Phase 0 (grocery "order this list" deep-links; consumer app)
# Master switch — when false, the app hides "Order online" entirely (no store names or URLs on the client).
COMMERCE_ENABLED=false
# Optional whitelist (comma-separated, order preserved). When set, only these partners are exposed.
# IDs: blinkit, zepto, instamart, bigbasket, jiomart
# COMMERCE_ENABLED_PARTNERS=blinkit,zepto
# Optional cap on how many partners the API returns (after whitelist/disable filtering). 0 = no cap.
# COMMERCE_MAX_PARTNERS=2
# Optional: hide specific partners, comma-separated (applied after whitelist)
# COMMERCE_DISABLED_PARTNERS=
# Store deep-link / search URLs live only in backend code — never in the frontend bundle.
# Optional: turn on commission once you join a free affiliate network (EarnKaro/Cuelinks/etc).
# Template per partner; {target} = url-encoded deep link, {subid} = our tracking id.
# COMMERCE_AFFILIATE_BLINKIT=https://affiliate.example.com/?url={target}&subid={subid}
# COMMERCE_AFFILIATE_BIGBASKET=

# Onboarding — force /onboarding/status to return onboarding_done=false for every user (repeat testing).
# Staging already does this via ENVIRONMENT=staging. Set false or remove after testing in production.
# ONBOARDING_ALWAYS_SHOW=true
# Optional: only reset onboarding for one account (email match, case-insensitive).
# ONBOARDING_PREVIEW_EMAIL=you@example.com
