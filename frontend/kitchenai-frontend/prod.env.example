# Copy this file to prod.env (gitignored) and fill in values for production builds.
# Loaded by the npm scripts in package.json via `dotenv` (DOTENV_CONFIG_PATH=prod.env).
# Vercel production (branch main, project kitchmate) must use the same EXPO_PUBLIC_* values.
# NOTE: EXPO_PUBLIC_* values are inlined into the client bundle and visible to end users.
# Commerce / store URLs are NOT configured here — backend COMMERCE_* env controls "Order online".

# Google OAuth Client IDs (must match backend GOOGLE_*_CLIENT_ID and eas.json production profile)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=208103249970-qg4bv6ilknfe52eqks8u662hp3toneua.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=208103249970-5j9v2282v0f9r0d8859shqmnurpc93lp.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=208103249970-ssbd98i8gqndd1o10vbaa6e5nfhkfcft.apps.googleusercontent.com

# Backend API URL (production Cloud Run)
EXPO_PUBLIC_API_BASE_URL=https://kitchenai-backend-208103249970.asia-south1.run.app/api/v1

# Web OAuth redirect (Vercel production)
# EXPO_PUBLIC_WEB_REDIRECT_URI=https://kitchmate-one.vercel.app

# Optional: Settings → App update (iOS needs this when published; Android uses package id by default)
# EXPO_PUBLIC_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.kitchenai.app
# EXPO_PUBLIC_APP_STORE_URL=https://apps.apple.com/app/idXXXXXXXXX
