# Copy this file to prod.env (gitignored) and fill in values for production builds.
# Loaded by the npm scripts in package.json via `dotenv` (DOTENV_CONFIG_PATH=prod.env).
# NOTE: EXPO_PUBLIC_* values are inlined into the client bundle and visible to end users.

# Google OAuth Client IDs (from Google Cloud Console)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Backend API URL
EXPO_PUBLIC_API_BASE_URL=
