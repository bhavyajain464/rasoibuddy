# Google OAuth Client IDs (from Google Cloud Console)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Backend API URL
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1

# Bill scan (photos/PDF) is handled by the backend (Google Vision OCR + Groq). No client OCR env vars.

# Optional: Google account that always sees onboarding (default: infinitystones464@gmail.com)
# EXPO_PUBLIC_ONBOARDING_PREVIEW_EMAIL=infinitystones464@gmail.com
