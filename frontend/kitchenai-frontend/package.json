{
  "name": "kitchenai-frontend",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "DOTENV_CONFIG_PATH=prod.env node -r dotenv/config ./node_modules/expo/bin/cli start --port 8082",
    "android": "DOTENV_CONFIG_PATH=prod.env node -r dotenv/config ./node_modules/expo/bin/cli run:android --port 8082",
    "android:launch": "bash scripts/launch-android-dev.sh",
    "android:dev": "DOTENV_CONFIG_PATH=prod.env node -r dotenv/config ./node_modules/expo/bin/cli start --port 8082 & sleep 3 && bash scripts/launch-android-dev.sh",
    "ios": "DOTENV_CONFIG_PATH=prod.env node -r dotenv/config ./node_modules/expo/bin/cli run:ios --port 8082",
    "web": "DOTENV_CONFIG_PATH=prod.env node -r dotenv/config ./node_modules/expo/bin/cli start --web --port 8082",
    "web:staging": "DOTENV_CONFIG_PATH=staging.env node -r dotenv/config ./node_modules/expo/bin/cli start --web --port 8082",
    "build:web": "DOTENV_CONFIG_PATH=prod.env node -r dotenv/config ./node_modules/expo/bin/cli export --platform web",
    "build:web:vercel": "expo export --platform web",
    "build:android:production": "npx eas-cli build --platform android --profile production",
    "doctor": "npx expo-doctor",
    "typecheck": "tsc --noEmit",
    "optimize:dishes": "node scripts/optimize-dish-images.mjs",
    "sync:staples": "node scripts/sync-staples-from-catalog.mjs",
    "generate:staple-images": "node scripts/generate-staple-images.mjs",
    "optimize:staples": "node scripts/optimize-staple-images.mjs",
    "sync:staple-generation": "node scripts/sync-staple-generation.mjs",
    "generate:staple-image-maps": "node scripts/generate-staple-image-maps.mjs",
    "generate:dish-images": "node scripts/generate-dish-image-maps.mjs",
    "lint": "expo lint"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-razorpay",
          "react-native-vector-icons"
        ],
        "listUnknownPackages": false
      }
    }
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.16.0",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.16.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "expo": "~54.0.35",
    "expo-application": "~7.0.8",
    "expo-auth-session": "~7.0.11",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-dev-client": "~6.0.21",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.23",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-screen-orientation": "~9.0.9",
    "expo-share-intent": "^5.1.1",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-paper": "^5.15.2",
    "react-native-razorpay": "^3.0.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "sharp": "^0.35.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
