# Copy to staging.env (gitignored) for local runs against the develop/staging stack.
# Vercel project "kitchmate-staging" should use the same EXPO_PUBLIC_* values.

# Google OAuth (same clients as prod until you create staging-only clients)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Staging Cloud Run (develop branch deploy)
EXPO_PUBLIC_API_BASE_URL=https://kitchenai-backend-staging-208103249970.asia-south1.run.app/api/v1
