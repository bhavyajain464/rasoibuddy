{
  "expo": {
    "name": "Kitchen AI",
    "slug": "kitchenai-frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "kitchenai",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kitchenai.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Kitchen AI needs camera access to scan grocery bills.",
        "NSPhotoLibraryUsageDescription": "Kitchen AI needs photo library access to select grocery bill images.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.kitchenai.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-share-intent",
        {
          "iosActivationRules": {
            "NSExtensionActivationSupportsText": true
          },
          "androidIntentFilters": ["text/*"]
        }
      ],
      "expo-image-picker",
      [
        "expo-camera",
        {
          "cameraPermission": "Kitchen AI needs camera access to scan grocery bills."
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.208103249970-5j9v2282v0f9r0d8859shqmnurpc93lp"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "packagingOptions": {
              "excludes": [
                "lib/x86/**",
                "lib/x86_64/**"
              ]
            }
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "6302f988-f489-4728-abed-1a067f024962"
      }
    }
  }
}
