{
  "expo": {
    "name": "Rasoi Buddy",
    "slug": "kitchenai-frontend",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "androidStatusBar": {
      "barStyle": "dark-content",
      "translucent": true
    },
    "newArchEnabled": true,
    "scheme": "kitchenai",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kitchenai.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Rasoi Buddy needs camera access to scan grocery bills.",
        "NSPhotoLibraryUsageDescription": "Rasoi Buddy needs photo library access to select grocery bill images.",
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": [
          "tez",
          "phonepe",
          "paytmmp",
          "bhim",
          "credpay"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "pan",
      "predictiveBackGestureEnabled": false,
      "package": "com.kitchenai.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "description": "Rasoi Buddy is your digital kitchen hub. Scan grocery bills, track pantry expiry, get smart meal ideas, and WhatsApp your cook — less waste, smarter meals.",
      "themeColor": "#2E7D32"
    },
    "plugins": [
      [
        "expo-share-intent",
        {
          "iosActivationRules": {
            "NSExtensionActivationSupportsText": true
          },
          "androidIntentFilters": [
            "text/*"
          ]
        }
      ],
      "expo-image-picker",
      [
        "expo-camera",
        {
          "cameraPermission": "Rasoi Buddy needs camera access to scan grocery bills."
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.208103249970-5j9v2282v0f9r0d8859shqmnurpc93lp"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#4CAF50",
          "defaultChannel": "meal-log-reminders"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "enableMinifyInReleaseBuilds": true,
            "extraProguardRules": "-keep class com.facebook.react.** { *; }\n-keep class com.facebook.hermes.** { *; }\n-keep class com.facebook.jni.** { *; }\n-keep class com.swmansion.reanimated.** { *; }\n-keep class com.facebook.react.turbomodule.** { *; }\n-keepattributes *Annotation*\n-dontwarn com.razorpay.**\n-keep class com.razorpay.** { *; }\n-optimizations !method/inlining/\n-keepclasseswithmembers class * { public void onPayment*(...); }\n-keep class com.google.android.gms.** { *; }\n-dontwarn com.google.android.gms.**\n-keep class com.reactnativegooglesignin.** { *; }",
            "packagingOptions": {
              "excludes": [
                "lib/x86/**",
                "lib/x86_64/**"
              ]
            }
          }
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-screen-orientation",
        {
          "initialOrientation": "DEFAULT"
        }
      ],
      "./plugins/withAndroidEdgeToEdgeReleaseFix.js"
    ],
    "extra": {
      "eas": {
        "projectId": "6302f988-f489-4728-abed-1a067f024962"
      }
    }
  }
}
