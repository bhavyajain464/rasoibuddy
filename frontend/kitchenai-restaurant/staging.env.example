# Copy to staging.env (gitignored) for local runs against the develop/staging stack.
# Vercel project rasoibuddy-partner (branch develop) uses the same EXPO_PUBLIC_* values.

# Google OAuth (same clients as consumer app; add partner web origin in Google Cloud Console)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Staging Cloud Run (develop branch backend)
EXPO_PUBLIC_API_BASE_URL=https://kitchenai-backend-staging-208103249970.asia-south1.run.app/api/v1

# Set to your deployed partner web URL after first Vercel deploy (for OAuth redirect)
# EXPO_PUBLIC_WEB_REDIRECT_URI=https://kitchmate-partner.vercel.app
