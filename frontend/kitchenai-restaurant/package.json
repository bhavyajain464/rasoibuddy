{
  "name": "kitchenai-restaurant",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "DOTENV_CONFIG_PATH=prod.env node -r dotenv/config ../node_modules/expo/bin/cli start --port 8083",
    "android": "DOTENV_CONFIG_PATH=prod.env node -r dotenv/config ../node_modules/expo/bin/cli run:android --port 8083",
    "ios": "DOTENV_CONFIG_PATH=prod.env node -r dotenv/config ../node_modules/expo/bin/cli run:ios --port 8083",
    "web": "DOTENV_CONFIG_PATH=prod.env node -r dotenv/config ../node_modules/expo/bin/cli start --web --port 8082",
    "build:web": "DOTENV_CONFIG_PATH=prod.env node -r dotenv/config ../node_modules/expo/bin/cli export --platform web",
    "build:web:vercel": "expo export --platform web",
    "web:staging": "DOTENV_CONFIG_PATH=staging.env node -r dotenv/config ../node_modules/expo/bin/cli start --web --port 8082",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kitchenai/api-core": "*",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-cookies/cookies": "^6.2.1",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.16.0",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.16.0",
    "expo": "~54.0.35",
    "expo-build-properties": "~1.0.10",
    "expo-dev-client": "~6.0.21",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-paper": "^5.15.2",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "^13.16.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "dotenv": "^16.4.7",
    "typescript": "~5.9.2"
  },
  "private": true
}
