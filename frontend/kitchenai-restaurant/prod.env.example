# Copy this file to prod.env (gitignored) and fill in values for local native builds.
# Loaded by npm scripts via `dotenv` (DOTENV_CONFIG_PATH=prod.env).
# EAS production profile env vars live in eas.json.

# Google OAuth Client IDs — restaurant app uses its own Android client (com.kitchenai.restaurant)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=208103249970-qg4bv6ilknfe52eqks8u662hp3toneua.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=208103249970-5j9v2282v0f9r0d8859shqmnurpc93lp.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=208103249970-3ajg7i1c481m0scdd8h3raf0h5j04csi.apps.googleusercontent.com

# Backend API URL (local dev — Android emulator uses 10.0.2.2 automatically)
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080

# Optional: Settings → App update
# EXPO_PUBLIC_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.kitchenai.restaurant
